


    <header class="bg-slate-950 shadow-xl border-b border-slate-800">
  <nav class="flex justify-between items-center px-8 py-4">

    <!-- Logo -->
    <div>
      
      
<h1 class="text-5xl md:text-4xl font-extrabold tracking-wide">
  
  <span class="bg-gradient-to-r from-pink-500 via-purple-500 to-indigo-500 bg-clip-text text-transparent">
    Airbnb
  </span>
</h1>
</div>

      <!-- <p class="text-sm text-slate-400"> -->


    <!-- Navigation Links -->
    <div class="flex items-center gap-6 ">

      <% if (isloggedIn) { %>
        <% if(user.userType === 'guest'){ %>

        <a href="/homes"
          class="px-5 py-2 rounded-xl bg-indigo-600 text-white
                 hover:bg-indigo-700 hover:scale-105
                 shadow-md hover:shadow-xl
                 transition-all duration-300">
          🏠 Homes
        </a>
        
        <a href="/favorites"
          class="px-5 py-2 rounded-xl bg-pink-600 text-white
                 hover:bg-pink-700 hover:scale-105
                 shadow-md hover:shadow-xl
                 transition-all duration-300">
          ❤️ Favorites
        </a>
        <% } else { %>

        <a href="/host-homes"
          class="px-5 py-2 rounded-xl bg-indigo-600 text-white
                 hover:bg-indigo-700 hover:scale-105
                 shadow-md hover:shadow-xl
                 transition-all duration-300">
          📋 Host Homes
        </a>


        <a href="/add-home"
          class="px-5 py-2 rounded-xl bg-emerald-500 text-white
                 hover:bg-emerald-600 hover:scale-105
                 shadow-md hover:shadow-xl
                 transition-all duration-300">
          ➕ Add Home
        </a>
        <% } %>

        <form action="/logout" method="POST">
          <button type="submit"
            class="px-5 py-2 rounded-xl bg-red-500 text-white
                   hover:bg-red-600 hover:scale-105
                   shadow-md hover:shadow-xl
                   transition-all duration-300">
            🚪 Logout
          </button>
        </form>

      <% } else { %>

        <a href="/signup"
          class="px-5 py-2 rounded-xl bg-emerald-500 text-white
                 hover:bg-emerald-600 hover:scale-105
                 shadow-md hover:shadow-xl
                 transition-all duration-300">
          ✨ Signup
        </a>

        <a href="/login"
          class="px-5 py-2 rounded-xl bg-indigo-600 text-white
                 hover:bg-indigo-700 hover:scale-105
                 shadow-md hover:shadow-xl
                 transition-all duration-300">
          🔑 Login
        </a>

      <% } %>

      <a href="/"
        class="px-5 py-2 rounded-xl border border-indigo-500
               text-indigo-400
               hover:bg-indigo-600 hover:text-white
               hover:scale-105
               transition-all duration-300">
        🏡 Airbnb
      </a>

    </div>
  </nav>
</header>