<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Home</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

 <body class="min-h-screen bg-slate-950
             bg-[radial-gradient(circle_at_top_left,_#4f46e5,_transparent_50%),radial-gradient(circle_at_bottom_right,_#ec4899,_transparent_30%)]"> 
  <%- include('../partials/nav')%>
  <br>
  <br>
  <div class="min-h-16 flex justify-center items-center">
    <!-- 🔥 Form Card -->
    <div class="bg-white shadow-2xl rounded-2xl p-8 w-full max-w-md mr-10">

        <!-- Heading -->
        <h1 class="text-3xl font-bold text-center 
                   bg-gradient-to-r from-indigo-600 to-pink-500 
                   text-transparent bg-clip-text mb-6">
          <%=editing ? "Edit" : "Add" %>Your Home 
        </h1>

        <!-- Form -->
        <form action="/host/<%= editing ? 'edit-home': 'add-home'%>" method="POST" class="space-y-5">
            <!-- input id add in this -->
           

            <!-- Input Field -->
            <div>
                 <input 
                    type="hidden" 
                    name="id" 
                
                    value="<%= editing ? home.id : ''%>"
                    
                />




                <label class="block text-gray-700 font-medium mb-2">
                    House Name
                </label>
                <input 
                    type="text" 
                    name="houseName" 
                    placeholder="Enter house name"
                    value="<%= editing ? home.houseName : ''%>"
                    required
                    class="w-full px-4 py-3 border-2 border-gray-300 
                           rounded-lg focus:outline-none 
                           focus:border-indigo-500 
                           focus:ring-2 focus:ring-indigo-200 
                           transition duration-300"
                />



                 <input 
                    type="number" 
                    name="price" 
                    placeholder="Enter price"
                      value="<%= editing ? home.price : ''%>"
                    required
                    class="w-full px-4 py-3 border-2 border-gray-300 
                           rounded-lg focus:outline-none 
                           focus:border-indigo-500 
                           focus:ring-2 focus:ring-indigo-200 
                           transition duration-300"
                />

                 <input 
                    type="text" 
                    name="location" 
                    placeholder="Enter your house location"
                      value="<%= editing ? home.location : ''%>"
                    required
                    class="w-full px-4 py-3 border-2 border-gray-300 
                           rounded-lg focus:outline-none 
                           focus:border-indigo-500 
                           focus:ring-2 focus:ring-indigo-200 
                           transition duration-300"
                />

                 <input 
                    type="number" 
                    name="rating" 
                    placeholder="rating"
                      value="<%= editing ? home.rating : ''%>"
                    required
                    class="w-full px-4 py-3 border-2 border-gray-300 
                           rounded-lg focus:outline-none 
                           focus:border-indigo-500 
                           focus:ring-2 focus:ring-indigo-200 
                           transition duration-300"
                />

                  <input 
                    type="text" 
                    name="photoUrl" 
                    placeholder=" photo url"
                      value="<%= editing ? home.photoUrl : ''%>"
                    required
                    class="w-full px-4 py-3 border-2 border-gray-300 
                           rounded-lg focus:outline-none 
                           focus:border-indigo-500 
                           focus:ring-2 focus:ring-indigo-200 
                           transition duration-300"
                />

                
            </div>

            <!-- Submit Button -->
            <input
                type="submit"
                value="<%= editing ? 'Update' : 'ADD'%>"
                class="w-full bg-indigo-600 text-white py-3 
                       rounded-lg font-semibold shadow-md 
                       hover:bg-indigo-800 
                       transition duration-300">
                
          </input>

        </form>

    </div>
    </div>

</body>
</html>