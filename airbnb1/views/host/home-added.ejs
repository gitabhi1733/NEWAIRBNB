}

.animate-fadeIn{
animation: fadeIn 1s ease forwards;
}
</style>

</head>

<body class="bg-gray-100 flex flex-col items-center justify-center ">



<div class="bg-white shadow-2xl rounded-2xl p-10 text-center max-w-md w-full animate-fadeIn">

