<div class="bg-green-100 p-4 rounded-full animate-bounce">
<svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" stroke-width="2"
viewBox="0 0 24 24">
<path stroke-linecap="round" stroke-linejoin="round"
d="M5 13l4 4L19 7" />
</svg>
</div>
</div>

<!-- Heading -->
<h1 class="text-2xl font-bold text-gray-800 mb-3">
Home Added Successfully 🎉
</h1>

<!-- Description -->
<p class="text-gray-500 mb-6">
Your property has been added successfully to the system.
</p>

<!-- Buttons -->
<div class="flex justify-center gap-4">

<a href="/"
class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition duration-300">
Go Home
</a>

</div>

</div>

