<%- include('../partials/head') %>
</head>

<!-- <body class="bg-[oklch(73.7%_0.021_106.9)]"> -->
     <body class="min-h-screen bg-slate-950
             bg-[radial-gradient(circle_at_top_left,_#4f46e5,_transparent_50%),radial-gradient(circle_at_bottom_right,_#ec4899,_transparent_30%)]"> 

    <!-- Navbar -->
    <%- include('../partials/nav')%>

    <!-- Heading Section -->
    <section class="text-center mt-10">
        <!-- <h2 class="text-4xl font-bold 
                   bg-gradient-to-r from-indigo-600 to-pink-500 
                   text-transparent bg-clip-text">
            WELCOME TO AIRBNB
        </h2> -->
        <h2 class="text-2xl md:text-4xl font-extrabold
           bg-gradient-to-r from-blue-600 via-purple-500 to-pink-500
           bg-clip-text text-transparent
           animate-pulse
           drop-shadow-lg
           tracking-wider">
    WELCOME TO AIRBNB
</h2>
    </section>

    <!-- Home Cards Container -->
    <div class="flex flex-wrap justify-center gap-8 mt-12 px-6">

        <% home.forEach(home => { %>

            <!-- Single Card -->
            <div class="w-80 bg-white rounded-3xl shadow-md 
                        hover:shadow-2xl transition duration-300 
                        overflow-hidden group">

                <!-- Image -->
                <div class="relative overflow-hidden">
                    <img src="<%= home.photoUrl %>" 
                         alt="Home Image"
                         class="w-full h-52 object-cover 
                                transform group-hover:scale-110 
                                transition duration-500">

                    <!-- Rating Badge -->
                    <a href="/star">
                    <div class="absolute top-3 right-3 
                                bg-white px-3 py-1 rounded-full 
                                shadow text-sm font-semibold 
                                text-yellow-500">
                                
                        ⭐ <%= home.rating %>
                          
                    </div>
                    </a>
                  
                </div>

                <!-- Content -->
                <div class="p-5 space-y-2">

                    <!-- House Name -->
                    <h2 class="text-xl font-bold text-gray-800">
                        <%= home.houseName %>
                    </h2>

                    <!-- Location -->
                    <p class="text-gray-500 text-sm">
                        📍 <%= home.location %>
                    </p>

                    <!-- Price -->
                    <p class="text-lg font-semibold text-indigo-600">
                        ₹ <%= home.price %>
                        <span class="text-gray-400 text-sm font-normal">
                            / night
                        </span>
                        <div class="text-center">
                         
                        </div>
                    </p>

                </div>
            </div>

        <% }); %>

    </div>

</body>
</html>