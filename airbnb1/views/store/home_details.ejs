<%- include('../partials/head') %>
</head>

<body class="bg-[oklch(43.8%_0.218_303.724)]">

<%- include('../partials/nav') %>

            <div class="max-w-2xl max-h-min ml-80 px-8 py-10 mt-10
            bg-white rounded-3xl 
            border border-gray-100
            shadow-2xl hover:shadow-indigo-200/40
            transition duration-300">

    <!-- Title Section -->
    <h1 class="text-3xl font-bold text-gray-800">
        <%= home.houseName %>
    </h1>

    <p class="text-gray-500 mt-1">
        📍 <%= home.location %> · ⭐ <%= home.rating %>
    </p>

    <!-- Image Gallery -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">

        <div>
            <img src="<%= home.photoUrl %>" 
                 class="w-full h-[400px] object-cover rounded-2xl">
        </div>

    </div>

    <!-- Main Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 mt-10">

        <!-- Left Content -->
        <div class="lg:col-span-2 space-y-8">

            <!-- Host Info -->
            <div class="border-b pb-6">
                <h2 class="text-2xl font-semibold">
                    Entire home hosted by Abhishek
                </h2>
                <p class="text-gray-500 mt-1">
                    4 guests · 2 bedrooms · 2 beds · 1 bath
                </p>
            </div>

            <!-- Amenities -->
            <div>
                <h3 class="text-xl font-semibold mb-4">
                    What this place offers
                </h3>

                <div class="grid grid-cols-2 gap-4 text-gray-700">
                    <p>📶 Free WiFi</p>
                    <p>❄ AC</p>
                    <p>🍳 Kitchen</p>
                    <p>🚗 Free Parking</p>
                    <p>📺 TV</p>
                    <p>🧺 Washing Machine</p>
                </div>
            </div>

            <!-- Description -->
            <div>
                <h3 class="text-xl font-semibold mb-3">
                    About this place
                </h3>

                <p class="text-gray-600 leading-relaxed">
                    <%= home.description || "Beautiful and comfortable stay in a peaceful location. Perfect for family trips and weekend getaways." %>
                </p>
                <%- include('../partials/add_to_favorite') %>
                
            </div>
          

        </div>

        <!-- Booking Card -->

    </div>

</div>

</body>
</html>